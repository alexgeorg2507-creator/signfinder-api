# SignFinder TEST environment — copy to .env.test, fill in real values, NEVER commit secrets.
# All secrets must be stored in Secret Manager; this file is a reference template only.

# ── Postgres (Cloud SQL) ──────────────────────────────────────────────────────
# For local dev via Cloud SQL Auth Proxy: postgresql+asyncpg://user:pass@localhost:5432/signfinder
# For Cloud Run (Unix socket): postgresql+asyncpg://user:pass@/signfinder?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://signfinder:CHANGE_ME@localhost:5432/signfinder
CLOUD_SQL_INSTANCE=signfinder-cab-test:europe-west1:signfinder-db
# Public IP (for local dev direct connection): 34.77.161.124

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=signfinder-cab-test
# Path to service account JSON downloaded from Firebase console (never commit the actual file)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-sa.json

# ── GCS (signatures storage) ─────────────────────────────────────────────────
GCS_BUCKET_NAME=signfinder-test-signatures
GCS_SIGNATURES_PREFIX=signatures/

# ── Existing SignFinder vars ──────────────────────────────────────────────────
API_KEY=CHANGE_ME
DEEPSEEK_API_KEY=CHANGE_ME
SF_DATA_DIR=/app/data

# ── Usage limits ─────────────────────────────────────────────────────────────
USAGE_FREE_LIMIT_PER_MONTH=10
