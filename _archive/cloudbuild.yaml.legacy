steps:
  - name: 'gcr.io/cloud-builders/docker'
    args:
      - 'build'
      - '-t'
      - 'gcr.io/$PROJECT_ID/signfinder-api:$COMMIT_SHA'
      - '-t'
      - 'gcr.io/$PROJECT_ID/signfinder-api:latest'
      - '.'

  - name: 'gcr.io/cloud-builders/docker'
    args:
      - 'push'
      - '--all-tags'
      - 'gcr.io/$PROJECT_ID/signfinder-api'

  - name: 'gcr.io/google.com/cloudsdktool/cloud-sdk'
    entrypoint: gcloud
    args:
      - 'run'
      - 'deploy'
      - 'signfinder-api'
      - '--image=gcr.io/$PROJECT_ID/signfinder-api:$COMMIT_SHA'
      - '--region=europe-west1'
      - '--platform=managed'
      - '--allow-unauthenticated'
      - '--set-secrets=API_KEY=signfinder-api-key:latest,ANTHROPIC_API_KEY=anthropic-api-key:latest'
      - '--set-env-vars=STORAGE_MODE=gcs,GCS_BUCKET=signfinder-config,ENVIRONMENT=production'
      - '--min-instances=0'
      - '--max-instances=10'
      - '--memory=2Gi'
      - '--cpu=1'
      - '--timeout=300'

images:
  - 'gcr.io/$PROJECT_ID/signfinder-api'
