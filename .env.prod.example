# SignFinder PROD environment — copy to .env.prod, fill in real values, NEVER commit secrets.
# All secrets must be stored in Secret Manager; this file is a reference template only.

# ── Postgres (Cloud SQL) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://signfinder:CHANGE_ME@/signfinder?host=/cloudsql/signfinder-prod:europe-west1:signfinder-db
# Public IP (для локальной прямой связи): 34.77.10.172
CLOUD_SQL_INSTANCE=signfinder-prod:europe-west1:signfinder-db

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=signfinder-prod
# GOOGLE_APPLICATION_CREDENTIALS не нужен на Cloud Run — ADC через прикреплённый
# service account. Нужен только для локальной разработки вне GCP, если вообще нужен.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-sa.json

# ── GCS (signatures storage) ─────────────────────────────────────────────────
GCS_BUCKET_NAME=signfinder-prod-signatures
GCS_SIGNATURES_PREFIX=signatures/

# ── Existing SignFinder vars ──────────────────────────────────────────────────
API_KEY=CHANGE_ME
DEEPSEEK_API_KEY=CHANGE_ME
SF_DATA_DIR=/app/data

# ── Usage limits ─────────────────────────────────────────────────────────────
USAGE_FREE_LIMIT_PER_MONTH=10
