# Storage backend
STORAGE_MODE=gcs
GCS_BUCKET=signfinder-config

# Для локальной разработки:
# STORAGE_MODE=local
# STORAGE_PATH=./signfinder_data

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# API авторизация — один статичный ключ в v1.9
API_KEY=sf_dev_your_secret_key_here

# Окружение
ENVIRONMENT=development
LOG_LEVEL=INFO

# PORT — Cloud Run устанавливает автоматически в 8080
# PORT=8080

# ---------------------------------------------------------------------------
# Async обработка (v1.9 Part 3)
# ---------------------------------------------------------------------------

# false = задача выполняется синхронно в том же процессе (локальная разработка)
# true  = ставим HTTP task в GCP Cloud Tasks (Cloud Run production)
CLOUD_TASKS_ENABLED=false

# Job storage — отдельно от STORAGE_PATH/GCS_BUCKET
JOBS_STORAGE_PATH=./signfinder_jobs   # используется при STORAGE_MODE=local
JOBS_BUCKET=signfinder-jobs           # используется при STORAGE_MODE=gcs

# Токен для Cloud Tasks → API callback (Internal endpoints)
# Задаём произвольную строку, должна совпадать в Cloud Tasks и API
INTERNAL_TOKEN=change_me_in_production

# Только при CLOUD_TASKS_ENABLED=true:
# GCP_PROJECT=your-gcp-project-id
# CLOUD_TASKS_LOCATION=europe-west1
# CLOUD_TASKS_QUEUE=signfinder-jobs
# API_INTERNAL_URL=https://signfinder-api-xxxx-ew.a.run.app
